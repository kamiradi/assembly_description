<mujoco model="rect_peg_in_hole_mesh">
  <!--
    Mesh-based rectangular peg-in-hole scene converted from the Drake/URDF
    assembly assets.

    This keeps the same research workflow as rect_peg_in_hole.xml:
    - insertion axis: world z
    - qvel index 0: peg insertion velocity along z
    - tracked body: "peg"
    - velocity actuator: command contact speed while MuJoCo/MJX resolves contact

    Mesh source files:
    - urdf/meshes/rectangular_peg.obj
    - urdf/meshes/rectangular_hole.obj

    Note: the peg OBJ's long axis is its local y axis. The peg geom is rotated
    +90 degrees about x so that its length is aligned with world z. The peg
    body is then yawed +90 degrees about world z so the rectangular
    cross-section lines up with the rectangular hole opening.
  -->

  <compiler angle="radian"
            meshdir="../urdf/meshes"/>

  <option timestep="0.005"
          solver="Newton"
          iterations="10"
          ls_iterations="50"
          gravity="0 0 0"
          cone="pyramidal"/>

  <custom>
    <numeric data="40" name="max_contact_points"/>
    <numeric data="40" name="max_geom_pairs"/>
  </custom>

  <visual>
    <global offwidth="1280" offheight="900"/>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.65 0.65 0.65" specular="0.1 0.1 0.1"/>
  </visual>

  <asset>
    <mesh name="rectangular_peg_mesh" file="rectangular_peg.obj"/>
    <mesh name="rectangular_hole_mesh" file="rectangular_hole.obj"/>

    <texture name="checker" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.92 0.92 0.88" rgb2="0.68 0.72 0.76"/>
    <material name="checker_mat" texture="checker" texrepeat="10 10" reflectance="0.15"/>
  </asset>

  <default>
    <geom condim="3"
          friction="1.0 0.005 0.0001"
          solref="0.01 1"
          solimp="0.9 0.95 0.001"/>
  </default>

  <worldbody>
    <light name="key_light" pos="0.35 -0.55 1.0" dir="-0.35 0.55 -1"/>
    <geom name="floor"
          type="plane"
          pos="0 0 -0.026"
          size="0.5 0.5 0.01"
          contype="0"
          conaffinity="0"
          material="checker_mat"/>

    <geom name="hole_collision"
          type="mesh"
          mesh="rectangular_hole_mesh"
          pos="0 0 0"
          contype="1"
          conaffinity="1"
          rgba="0.68 0.73 0.82 1"/>

    <body name="peg" pos="0.006 0 0.23" euler="0 0 1.5707963267948966">
      <joint name="insertion_slide" type="slide" axis="0 0 1"/>
      <geom name="peg_collision"
            type="mesh"
            mesh="rectangular_peg_mesh"
            euler="1.5707963267948966 0 0"
            mass="0.49468"
            contype="1"
            conaffinity="1"
            rgba="0.95 0.58 0.44 1"/>
    </body>
  </worldbody>

  <actuator>
    <velocity name="insertion_velocity_servo"
              joint="insertion_slide"
              kv="20"
              ctrllimited="true"
              ctrlrange="-1 1"/>
  </actuator>
</mujoco>
