<mujoco model="rect_peg_in_hole_soft">
  <!--
    Softer-contact variant of rect_peg_in_hole.xml for IFT/backend ablations.

    Geometry, jointing, actuator, and trajectory assumptions match the baseline
    primitive scene. The intentional changes are:
    - Newton solver made explicit
    - high line-search iteration budget made explicit
    - softer, smoother contact onset via solref/solimp

    Coordinate convention:
    - insertion axis: world z
    - qvel index 0: peg insertion velocity along z
    - tracked body: "peg"
  -->

  <option timestep="0.005"
          solver="Newton"
          iterations="10"
          ls_iterations="50"
          gravity="0 0 0"
          cone="pyramidal"/>

  <visual>
    <global offwidth="1280" offheight="900"/>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.65 0.65 0.65" specular="0.1 0.1 0.1"/>
  </visual>

  <asset>
    <texture name="checker" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.92 0.92 0.88" rgb2="0.68 0.72 0.76"/>
    <material name="checker_mat" texture="checker" texrepeat="10 10" reflectance="0.15"/>
  </asset>

  <default>
    <!--
      Softer than the baseline:
      - solref time constant 0.03 s is 6x the 0.005 s timestep and 3x the
        baseline contact time constant.
      - solimp starts at d0=0 for smoother contact onset, as suggested by the
        MuJoCo docs for differentiable contacts.
      - width=0.01 gives a broader soft contact layer than the baseline 0.001.
    -->
    <geom condim="3"
          friction="1.0 0.005 0.0001"
          solref="0.03 1"
          solimp="0 0.9 0.01 0.5 2"/>
  </default>

  <worldbody>
    <light name="key_light" pos="0.35 -0.55 1.0" dir="-0.35 0.55 -1"/>
    <geom name="floor"
          type="plane"
          pos="0 0 -0.026"
          size="0.5 0.5 0.01"
          contype="0"
          conaffinity="0"
          material="checker_mat"/>

    <geom name="table_collision"
          type="box"
          pos="0 0 -0.0125"
          size="0.16 0.16 0.0125"
          contype="1"
          conaffinity="1"
          rgba="0.78 0.80 0.82 1"/>

    <geom name="hole_wall_pos_x_collision"
          type="box"
          pos="0.05 0 0.03"
          size="0.01 0.06 0.03"
          contype="1"
          conaffinity="1"
          rgba="0.68 0.73 0.82 1"/>
    <geom name="hole_wall_neg_x_collision"
          type="box"
          pos="-0.05 0 0.03"
          size="0.01 0.06 0.03"
          contype="1"
          conaffinity="1"
          rgba="0.68 0.73 0.82 1"/>
    <geom name="hole_wall_pos_y_collision"
          type="box"
          pos="0 0.05 0.03"
          size="0.04 0.01 0.03"
          contype="1"
          conaffinity="1"
          rgba="0.68 0.73 0.82 1"/>
    <geom name="hole_wall_neg_y_collision"
          type="box"
          pos="0 -0.05 0.03"
          size="0.04 0.01 0.03"
          contype="1"
          conaffinity="1"
          rgba="0.68 0.73 0.82 1"/>

    <body name="peg" pos="0.006 0 0.17">
      <joint name="insertion_slide" type="slide" axis="0 0 1"/>
      <geom name="peg_collision"
            type="box"
            size="0.0355 0.0355 0.09"
            mass="0.49468"
            contype="1"
            conaffinity="1"
            rgba="0.95 0.58 0.44 1"/>
    </body>
  </worldbody>

  <actuator>
    <velocity name="insertion_velocity_servo"
              joint="insertion_slide"
              kv="20"
              ctrllimited="true"
              ctrlrange="-1 1"/>
  </actuator>
</mujoco>
