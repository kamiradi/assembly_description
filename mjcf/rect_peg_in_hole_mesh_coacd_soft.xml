<mujoco model="rect_peg_in_hole_mesh_coacd_soft">
  <!--
    CoACD convex-decomposition variant of rect_peg_in_hole_mesh_soft.xml.

    Visual geometry is unchanged from the mesh scene. Collision geometry uses
    OBJ files generated by:

      models/convex_decompose_coacd.py ... 

    With threshold=0.05, CoACD produced one convex part for the hole and one
    convex part for the peg.  This file deliberately reflects that requested
    decomposition; visually inspect the collision geometry because a single
    convex hull of a plate-with-hole may close the aperture.
  -->

  <compiler angle="radian"
            meshdir="../urdf/meshes"/>

  <option timestep="0.005"
          solver="Newton"
          iterations="10"
          ls_iterations="50"
          gravity="0 0 0"
          cone="pyramidal"/>

  <custom>
    <numeric data="40" name="max_contact_points"/>
    <numeric data="40" name="max_geom_pairs"/>
  </custom>

  <visual>
    <global offwidth="1280" offheight="900"/>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.65 0.65 0.65" specular="0.1 0.1 0.1"/>
  </visual>

  <asset>
    <mesh name="rectangular_peg_visual_mesh" file="rectangular_peg.obj"/>
    <mesh name="rectangular_hole_visual_mesh" file="rectangular_hole.obj"/>
    <mesh name="rectangular_peg_coacd_000_mesh"
          file="coacd_rect_peg_in_hole/rectangular_peg_coacd_000.obj"/>
    <mesh name="rectangular_hole_coacd_000_mesh"
          file="coacd_rect_peg_in_hole/rectangular_hole_coacd_000.obj"/>

    <texture name="checker" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.92 0.92 0.88" rgb2="0.68 0.72 0.76"/>
    <material name="checker_mat" texture="checker" texrepeat="10 10" reflectance="0.15"/>
  </asset>

  <default>
    <geom condim="3"
          friction="1.0 0.005 0.0001"
          solref="0.03 1"
          solimp="0 0.9 0.01 0.5 2"/>
  </default>

  <worldbody>
    <light name="key_light" pos="0.35 -0.55 1.0" dir="-0.35 0.55 -1"/>
    <geom name="floor"
          type="plane"
          pos="0 0 -0.026"
          size="0.5 0.5 0.01"
          contype="0"
          conaffinity="0"
          material="checker_mat"/>

    <geom name="hole_visual"
          type="mesh"
          mesh="rectangular_hole_visual_mesh"
          pos="0 0 0"
          contype="0"
          conaffinity="0"
          rgba="0.68 0.73 0.82 0.35"/>
    <geom name="hole_coacd_000_collision"
          type="mesh"
          mesh="rectangular_hole_coacd_000_mesh"
          pos="0 0 0"
          contype="1"
          conaffinity="1"
          rgba="0.14 0.25 0.55 0.35"/>

    <body name="peg" pos="0.006 0 0.23" euler="0 0 1.5707963267948966">
      <joint name="insertion_slide" type="slide" axis="0 0 1"/>
      <geom name="peg_visual"
            type="mesh"
            mesh="rectangular_peg_visual_mesh"
            euler="1.5707963267948966 0 0"
            density="0"
            contype="0"
            conaffinity="0"
            rgba="0.95 0.58 0.44 0.35"/>
      <geom name="peg_coacd_000_collision"
            type="mesh"
            mesh="rectangular_peg_coacd_000_mesh"
            euler="1.5707963267948966 0 0"
            mass="0.49468"
            contype="1"
            conaffinity="1"
            rgba="0.85 0.18 0.12 0.45"/>
    </body>
  </worldbody>

  <actuator>
    <velocity name="insertion_velocity_servo"
              joint="insertion_slide"
              kv="20"
              ctrllimited="true"
              ctrlrange="-1 1"/>
  </actuator>
</mujoco>
